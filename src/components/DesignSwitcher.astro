---
import type { Locale } from '../content';
import { withBase } from '../utils/paths';

interface Props {
  locale: Locale;
  current: 'control' | 'midnight' | 'codex' | 'riceos' | 'zarocos';
}

const { locale, current } = Astro.props;
const labels = locale === 'de'
  ? { control: 'Control Room', midnight: 'Midnight Index', codex: 'ZAROC Kodex', riceos: 'RiceOS', zarocos: 'ZAROC OS', title: 'Design wählen' }
  : { control: 'Control Room', midnight: 'Midnight Index', codex: 'ZAROC Codex', riceos: 'RiceOS', zarocos: 'ZAROC OS', title: 'Choose design' };
const designs = [
  { id: 'midnight', number: '01', href: withBase(`/${locale}/midnight/`) },
  { id: 'control', number: '02', href: withBase(`/${locale}/`) },
  { id: 'codex', number: '03', href: withBase(`/${locale}/codex/`) },
  { id: 'riceos', number: '04', href: withBase(`/${locale}/riceos/`) },
  { id: 'zarocos', number: '05', href: withBase(`/${locale}/`) },
] as const;
---
<details class="design-switcher">
  <summary aria-label={labels.title}>
    <span class="ds-palette" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i></span>
    <span class="ds-current">D/{designs.find((design) => design.id === current)?.number}</span>
    <svg viewBox="0 0 16 16" aria-hidden="true"><path d="m4 6 4 4 4-4" /></svg>
  </summary>
  <nav aria-label={labels.title}>
    <p>{labels.title}</p>
    {designs.map((design) => (
      <a href={design.href} aria-current={current === design.id ? 'page' : undefined}>
        <span>{design.number}</span>
        <strong>{labels[design.id]}</strong>
        <i aria-hidden="true"></i>
      </a>
    ))}
  </nav>
</details>

<style>
  .design-switcher {
    --ds-bg: #1e2030;
    --ds-surface: #24273a;
    --ds-line: #363a4f;
    --ds-text: #cad3f5;
    --ds-muted: #8087a2;
    position: fixed;
    z-index: 900;
    right: 18px;
    bottom: 18px;
    color: var(--ds-text);
    font: 500 10px/1.2 'IBM Plex Mono', ui-monospace, monospace;
  }
  .design-switcher summary {
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 38px;
    padding: 7px 9px;
    background: color-mix(in srgb, var(--ds-bg) 92%, transparent);
    border: 1px solid var(--ds-line);
    border-radius: 8px;
    box-shadow: 0 12px 35px #0006;
    cursor: pointer;
    list-style: none;
    backdrop-filter: blur(14px);
  }
  .design-switcher summary::-webkit-details-marker { display: none; }
  .design-switcher summary svg { width: 12px; fill: none; stroke: var(--ds-muted); stroke-width: 1.3; transition: transform .2s ease; }
  .design-switcher[open] summary svg { transform: rotate(180deg); }
  .ds-current { color: var(--ds-muted); letter-spacing: .05em; }
  .ds-palette { display: flex; gap: 5px; padding-right: 9px; border-right: 1px solid var(--ds-line); }
  .ds-palette i { width: 7px; height: 7px; border-radius: 50%; background: #8087a2; }
  .ds-palette i:nth-child(2) { background: #cad3f5; }
  .ds-palette i:nth-child(3) { background: #8aadf4; }
  .ds-palette i:nth-child(4) { background: #7dc4e4; }
  .ds-palette i:nth-child(5) { background: #b7bdf8; }
  .ds-palette i:nth-child(6) { background: #91d7e3; }
  .ds-palette i:nth-child(7) { background: #8bd5ca; }
  .ds-palette i:nth-child(8) { background: #ee99a0; }
  .design-switcher nav {
    position: absolute;
    right: 0;
    bottom: calc(100% + 8px);
    width: 230px;
    padding: 8px;
    background: color-mix(in srgb, var(--ds-bg) 95%, transparent);
    border: 1px solid var(--ds-line);
    border-radius: 9px;
    box-shadow: 0 20px 55px #0008;
    backdrop-filter: blur(18px);
  }
  .design-switcher nav p { margin: 6px 8px 10px; color: var(--ds-muted); font-size: 8px; text-transform: uppercase; letter-spacing: .12em; }
  .design-switcher nav a { display: grid; grid-template-columns: 25px 1fr 7px; align-items: center; gap: 8px; padding: 10px 8px; color: var(--ds-muted); border-radius: 5px; text-decoration: none; }
  .design-switcher nav a:hover, .design-switcher nav a[aria-current='page'] { color: var(--ds-text); background: var(--ds-surface); }
  .design-switcher nav a span { font-size: 8px; }
  .design-switcher nav a strong { font-weight: 500; }
  .design-switcher nav a i { width: 6px; height: 6px; background: var(--ds-line); border-radius: 50%; }
  .design-switcher nav a[aria-current='page'] i { background: #8bd5ca; box-shadow: 0 0 8px #8bd5ca; }
  @media (max-width: 560px) {
    .design-switcher { right: 10px; bottom: 10px; }
    .ds-palette i:nth-child(even) { display: none; }
    .design-switcher nav { width: 210px; }
  }
</style>
