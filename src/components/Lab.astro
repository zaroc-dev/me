---
import type { SiteContent } from '../content';
interface Props { content: SiteContent }
const { content } = Astro.props;
---
<section class="section lab-section shell" id="lab" aria-labelledby="lab-title">
  <header class="section-heading" data-reveal>
    <p class="eyebrow"><span>03</span>{content.lab.eyebrow}</p>
    <div>
      <h2 id="lab-title">{content.lab.title}</h2>
      <p>{content.lab.intro}</p>
    </div>
  </header>

  <div class="lab-grid">
    {content.lab.cards.map((card) => (
      <article class="lab-card" data-reveal>
        <div class="lab-code">LAB::{card.code}</div>
        <div class="lab-icon" aria-hidden="true">
          {card.code === '01' && <svg viewBox="0 0 24 24"><path d="M4 5h16v12H4zM8 21h8M12 17v4M7 9l2 2-2 2m4 0h4"/></svg>}
          {card.code === '02' && <svg viewBox="0 0 24 24"><path d="M8 5a4 4 0 1 0-4 4h4V5Zm8 0a4 4 0 1 1 4 4h-4V5ZM8 19a4 4 0 1 1-4-4h4v4Zm8 0a4 4 0 1 0 4-4h-4v4ZM8 9h8v6H8z"/></svg>}
          {card.code === '03' && <svg viewBox="0 0 24 24"><path d="M3 19c5-2 8-2 9 1 1-3 4-3 9-1V5c-5-2-8-2-9 1-1-3-4-3-9-1v14ZM12 6v14"/></svg>}
          {card.code === '04' && <svg viewBox="0 0 24 24"><path d="M7 8h10l3 7-2 3-4-3h-4l-4 3-2-3 3-7ZM9 11v4m-2-2h4m5-1h.01m2 2h.01"/></svg>}
        </div>
        <h3>{card.title}</h3>
        <p>{card.description}</p>
        <span class="lab-detail">{card.detail}</span>
      </article>
    ))}
  </div>

  <aside class="principle" data-reveal>
    <span>{content.lab.quoteLabel}</span>
    <blockquote>“{content.lab.quote}”</blockquote>
    <div class="principle-line" aria-hidden="true"><i></i><i></i><i></i></div>
  </aside>
</section>
