---
import type { SiteContent } from '../content';
interface Props { content: SiteContent }
const { content } = Astro.props;
---
<section class="hero shell" aria-labelledby="hero-title">
  <div class="constellation" aria-hidden="true">
    <svg viewBox="0 0 560 430" fill="none">
      <path d="M36 326 146 207l86 37 90-154 88 83 111-122" />
      <path d="m146 207 11 132 165-42 88-124 50 154" />
      <circle cx="36" cy="326" r="3"/><circle cx="146" cy="207" r="4"/><circle cx="232" cy="244" r="3"/>
      <circle cx="322" cy="90" r="4"/><circle cx="410" cy="173" r="3"/><circle cx="521" cy="51" r="4"/>
      <circle cx="157" cy="339" r="3"/><circle cx="322" cy="297" r="4"/><circle cx="460" cy="327" r="3"/>
    </svg>
  </div>
  <div class="hero-copy" data-reveal>
    <p class="eyebrow"><span>00</span>{content.hero.eyebrow}</p>
    <h1 id="hero-title">{content.hero.title}<br /><em>{content.hero.accent}</em></h1>
    <p class="hero-intro">{content.hero.intro}</p>
    <div class="hero-actions">
      <a class="button primary" href="#work">
        <span>{content.hero.primary}</span>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14m-5-5 5 5-5 5" /></svg>
      </a>
      <a class="button ghost" href="https://github.com/zaroc-dev" target="_blank" rel="noreferrer">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3.28-.36 6.72-1.61 6.72-7.25A5.65 5.65 0 0 0 19.22 3.3 5.4 5.4 0 0 0 19.08.3S17.9-.08 15 1.8a13.4 13.4 0 0 0-7 0C5.1-.08 3.92.3 3.92.3a5.4 5.4 0 0 0-.14 3A5.65 5.65 0 0 0 2.28 7.3c0 5.6 3.44 6.85 6.72 7.25A4.8 4.8 0 0 0 8 18v4" /></svg>
        <span>{content.hero.secondary}</span>
      </a>
    </div>
  </div>

  <aside class="session-card" data-reveal aria-label={content.hero.terminalLabel}>
    <div class="panel-bar">
      <div class="panel-lights" aria-hidden="true"><i></i><i></i><i></i></div>
      <span>{content.hero.terminalLabel}</span>
      <span class="panel-id">tty_01</span>
    </div>
    <div class="session-body">
      <div class="ascii-mark" aria-hidden="true">
        <span>╭─────────╮</span>
        <span>│ Z A R O C │</span>
        <span>╰────┬────╯</span>
      </div>
      <dl>
        {content.hero.terminal.map((line) => <div><dt>{line.key}</dt><dd>{line.value}</dd></div>)}
      </dl>
      <p class="terminal-prompt"><span>zaroc@home</span>:~$ <i>{content.hero.terminalPrompt}</i><b aria-hidden="true"></b></p>
    </div>
  </aside>
</section>

<section class="stats-strip" aria-label="Highlights">
  <div class="stats-inner shell">
    {content.stats.map((stat, index) => (
      <div class="stat" data-reveal>
        <span class="stat-index">0{index + 1}</span>
        <strong>{stat.value}</strong>
        <span>{stat.label}</span>
      </div>
    ))}
  </div>
</section>
