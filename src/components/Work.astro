---
import type { SiteContent } from '../content';
interface Props { content: SiteContent }
const { content } = Astro.props;
const featured = content.work.projects.filter((project) => project.featured);
const rest = content.work.projects.filter((project) => !project.featured);
---
<section class="section work-section shell" id="work" aria-labelledby="work-title">
  <header class="section-heading" data-reveal>
    <p class="eyebrow"><span>01</span>{content.work.eyebrow}</p>
    <div>
      <h2 id="work-title">{content.work.title}</h2>
      <p>{content.work.intro}</p>
    </div>
  </header>

  <div class="featured-grid">
    {featured.map((project, index) => (
      <article class:list={['project-card', 'featured-project', `project-${index + 1}`]} data-reveal data-command-project={project.title.toLowerCase()}>
        <div class="project-topline">
          <span class="project-index">/{project.index}</span>
          <span class="project-status"><i aria-hidden="true"></i>{project.status}</span>
        </div>
        <div class="project-glyph" aria-hidden="true">
          {project.id === 'valstore' ? (
            <svg viewBox="0 0 160 160"><path d="m27 29 53 105 53-105-28 14-25 53-25-53-28-14Z"/><path d="m55 43 25 53 25-53"/></svg>
          ) : (
            <svg viewBox="0 0 160 160"><path d="M28 118V42h104v76H28Z"/><path d="M28 63h104M47 52h1m12 0h1m12 0h1M51 89h58M51 103h39"/></svg>
          )}
        </div>
        <div class="project-main">
          <div>
            <h3>{project.title}</h3>
            <p>{project.description}</p>
          </div>
          {project.metric && <div class="project-metric"><strong>{project.metric}</strong><span>{project.metricLabel}</span></div>}
        </div>
        <div class="project-footer">
          <ul aria-label="Technologies">{project.tags.map((tag) => <li>{tag}</li>)}</ul>
          {project.href && (
            <a href={project.href} target="_blank" rel="noreferrer" aria-label={`${content.work.viewProject}: ${project.title}`}>
              <span>{content.work.viewProject}</span>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 17 17 7M8 7h9v9" /></svg>
            </a>
          )}
        </div>
      </article>
    ))}
  </div>

  <div class="project-grid">
    {rest.map((project) => (
      <article class="project-card compact-project" data-reveal data-command-project={project.title.toLowerCase()}>
        <div class="project-topline">
          <span class="project-index">/{project.index}</span>
          <span class="project-status"><i aria-hidden="true"></i>{project.status}</span>
        </div>
        <div class="compact-body">
          <h3>{project.title}</h3>
          <p>{project.description}</p>
        </div>
        <div class="project-footer">
          <ul aria-label="Technologies">{project.tags.map((tag) => <li>{tag}</li>)}</ul>
          {project.href && (
            <a class="icon-link" href={project.href} target="_blank" rel="noreferrer" aria-label={`${content.work.viewProject}: ${project.title}`}>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 17 17 7M8 7h9v9" /></svg>
            </a>
          )}
        </div>
      </article>
    ))}
  </div>
</section>
